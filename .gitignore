# dependencies
node_modules
.pnpm-store

# build
dist
# 仅根级 build/ (build-cli-bundle 中间产物);裸 `build` 会误伤 server/src/build/
# .gitignore 不支持行内 # 注释,这条单独成行
/build
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
Thumbs.db

# coverage / test
coverage
.nyc_output

# vite / nest cache
.vite
.cache

# unplugin-auto-import / unplugin-vue-components 在每次 vite build 都会重写这两个文件
# (依据当前组件 / API 用法生成),不该 tracked,否则 release/CI 流程的 clean-tree 校验会误报
web/auto-imports.d.ts
web/components.d.ts

# 内部设计稿(给 maintainer 的草稿,非 OSS 内容)
notes

# Claude Code agent 会话历史(本地排查用,不入仓库)
.cc-history
